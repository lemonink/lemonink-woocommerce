{
	"name": "lemonink/lemonink-woocommerce",
	"description": "Woocommerce plugin for watermarking ebooks using LemonInk",
	"keywords": [
		"LemonInk",
		"woocommerce-plugin",
		"wordpress-plugin",
		"watermarking",
		"api"
	],
	"homepage": "https://lemonink.co/",
	"license": "MIT",
	"authors": [
		{
			"name": "LemonInk",
			"homepage": "https://lemonink.co/"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": ">=5.3.3",
		"lemonink/lemonink-php": ">=1.1.0"
	},
	"autoload": {
		"psr-0": { "LemonInk\\" : "src/" }
	},
	"config": {
		"vendor-dir": "src/vendor"
	}
}
