# Copy to .env and fill in. .env is gitignored — never commit real values.

# LemonInk test-mode API key, used to seed the dev store and to run the
# compatibility/e2e checks against the real LemonInk API.
LEMONINK_API_KEY=

# A master file ID that exists on the LemonInk account above, with at least
# one watermarkable format. Used when seeding products and running e2e.
LEMONINK_MASTER_ID=

# WordPress.org plugin SVN credentials, used by bin/release only.
SVN_USERNAME=
SVN_PASSWORD=
