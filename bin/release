#!/bin/bash
set -e
cd "$(dirname "$0")/.."

# Publish a release to the WordPress.org plugin SVN repository.
# Usage: SVN_USERNAME=... SVN_PASSWORD=... bin/release major|minor|patch|<X.Y.Z>
# The version argument sets the plugin version (header, readme, package.json)
# via bin/bump-version, then that version is built and tagged. Credentials are
# read from the environment (e.g. an untracked .env) and must never be committed.

[ -f .env ] && set -a && . ./.env && set +a

ARG="$1"
: "${ARG:?Usage: bin/release major|minor|patch|<X.Y.Z>}"
: "${SVN_USERNAME:?Set SVN_USERNAME in your environment or .env}"
: "${SVN_PASSWORD:?Set SVN_PASSWORD in your environment or .env}"

# Set the version in all source files (validates ARG; aborts on bad input).
bin/bump-version "$ARG"
VERSION=$(grep -oE 'Version:[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+' src/lemonink.php | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

bin/build

SVN_URL="https://plugins.svn.wordpress.org/lemonink"
SVN_AUTH=(--username="$SVN_USERNAME" --password="$SVN_PASSWORD" --non-interactive)

# Only ever touch trunk (and assets). Old tags can contain historical cruft
# (vendor/.git, guzzle, ...) committed years ago; a full checkout would pull
# all of it down and operate over it. A sparse checkout fetches just trunk and
# assets, and the new tag is created server-side from the committed trunk.
rm -rf svn
svn checkout --depth=immediates "$SVN_URL" svn "${SVN_AUTH[@]}"
svn update --set-depth=infinity svn/trunk "${SVN_AUTH[@]}"
svn update --set-depth=infinity svn/assets "${SVN_AUTH[@]}" 2>/dev/null || true

# Mirror trunk to the freshly built (clean) plugin: --delete removes stale
# files from older releases, --exclude='.svn/' preserves SVN's admin dirs. The
# WP.org /assets images live under assets/, not trunk/, so they are excluded
# here and copied separately.
mkdir -p svn/trunk svn/assets
rsync -a --delete --exclude='.svn/' --exclude='/assets/' tmp/lemonink/ svn/trunk/
cp -r tmp/lemonink/assets/* svn/assets/ 2>/dev/null || true

cd svn
# Stage adds/deletes within trunk and assets only.
svn add --force trunk assets >/dev/null
svn status trunk assets | awk '/^!/ { print $2 }' | xargs -r svn rm >/dev/null
svn commit -m "Update trunk for $VERSION" "${SVN_AUTH[@]}"

# Create the release tag server-side from the just-committed trunk, so no old
# tags are ever checked out or rewritten locally.
svn cp "$SVN_URL/trunk" "$SVN_URL/tags/$VERSION" \
  -m "Tagging version $VERSION" "${SVN_AUTH[@]}"
