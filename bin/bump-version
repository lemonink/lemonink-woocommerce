#!/bin/bash
set -e
cd "$(dirname "$0")/.."

# Bump the plugin version (semver) in all the places it lives: the plugin
# header (src/lemonink.php), the readme Stable tag (src/readme.txt), and
# package.json. The current version is read from the plugin header.
# Usage: bin/bump-version major|minor|patch

PART="$1"
case "$PART" in
	major|minor|patch) ;;
	*) echo "Usage: bin/bump-version major|minor|patch" >&2; exit 1 ;;
esac

CURRENT=$(grep -oE 'Version:[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+' src/lemonink.php | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
if [ -z "$CURRENT" ]; then
	echo "Error: could not read current version from src/lemonink.php" >&2
	exit 1
fi

IFS=. read -r MAJOR MINOR PATCH <<< "$CURRENT"
case "$PART" in
	major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
	minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
	patch) PATCH=$((PATCH + 1)) ;;
esac
NEW="${MAJOR}.${MINOR}.${PATCH}"

# Plugin header:  " * Version: X.Y.Z"
sed -i -E "s|^([[:space:]]*\*[[:space:]]*Version:[[:space:]]*).*|\1${NEW}|" src/lemonink.php
# readme:         "Stable tag: X.Y.Z"
sed -i -E "s/^(Stable tag:[[:space:]]*).*/\1${NEW}/" src/readme.txt
# package.json:   "version": "X.Y.Z"
sed -i -E "s/(\"version\":[[:space:]]*\")[0-9]+\.[0-9]+\.[0-9]+(\")/\1${NEW}\2/" package.json

echo "Bumped version: ${CURRENT} -> ${NEW}"
grep -nH -E "Version:|Stable tag:|\"version\"" src/lemonink.php src/readme.txt package.json | grep -F "$NEW"
