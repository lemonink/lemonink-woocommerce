#!/bin/bash
set -e
cd "$(dirname "$0")/.."

# Update the WordPress "Tested up to" version in both the readme and the plugin
# header, after you've confirmed compatibility (e.g. with bin/compat).
# Usage: bin/tested-up-to <wp-version>     e.g. bin/tested-up-to 6.9

VERSION="$1"
: "${VERSION:?Usage: bin/tested-up-to <wp-version>   e.g. bin/tested-up-to 6.9}"

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+(\.[0-9]+)?$ ]]; then
	echo "Error: '$VERSION' is not a valid WordPress version (expected e.g. 6.9)" >&2
	exit 1
fi

# readme.txt:            "Tested up to: X"
sed -i -E "s/^(Tested up to:[[:space:]]*).*/\1${VERSION}/" src/readme.txt
# lemonink.php header:   " * Tested up to: X"
sed -i -E "s|^([[:space:]]*\*[[:space:]]*Tested up to:[[:space:]]*).*|\1${VERSION}|" src/lemonink.php

echo "Set 'Tested up to' to ${VERSION}:"
grep -nH "Tested up to" src/readme.txt src/lemonink.php
